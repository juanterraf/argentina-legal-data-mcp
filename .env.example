# ── Argentina Legal & Data MCP — example environment ───────────────────────────
# Copy to `.env` and adjust. Nothing here is secret by default; the API-keys file
# (see AUTH) is what protects a remote deployment.

# ── Transport ──────────────────────────────────────────────────────────────────
# stdio | streamable-http | sse
ARGMCP_TRANSPORT=stdio
# Bind address/port for HTTP transports
ARGMCP_HOST=127.0.0.1
ARGMCP_PORT=8000

# ── Storage / cache ──────────────────────────────────────────────────────────--
# Directory for the SQLite dataset, diskcache, and health DB.
ARGMCP_DATA_DIR=./data
ARGMCP_CACHE_DIR=./.cache
# Path to the SQLite dataset built from the official ZIP.
ARGMCP_DATASET_PATH=./data/infoleg.sqlite

# ── InfoLEG live client ────────────────────────────────────────────────────────
ARGMCP_INFOLEG_BASE_URL=https://servicios.infoleg.gob.ar/infolegInternet
# Honest, identifiable User-Agent (be a good citizen of public infra).
ARGMCP_USER_AGENT=argentina-legal-data-mcp/0.1 (+https://github.com/your-org/argentina-legal-data-mcp)
ARGMCP_HTTP_TIMEOUT=20
ARGMCP_SESSION_TTL=300

# ── Pagination / chunking ───────────────────────────────────────────────────---
ARGMCP_INFOLEG_PAGE_SIZE=50
ARGMCP_MCP_PAGE_SIZE=5
ARGMCP_TEXT_CHUNK_SIZE=2000

# ── Auth (HTTP transports only; ignored on stdio) ───────────────────────────────
# When true, tools/call requires a Bearer credential; discovery stays open.
ARGMCP_AUTH_ENABLED=false
# JSON file: { "keys": [ { "key": "...", "name": "...", "active": true, "role": "user" } ] }
ARGMCP_API_KEYS_PATH=./secrets/api-keys.json
# Optional JWT (Context-Protocol style). Leave blank to disable.
ARGMCP_JWT_AUDIENCE=

# ── Backend (default sqlite; postgres optional, Phase 3) ─────────────────────────
ARGMCP_BACKEND=sqlite
# ARGMCP_PG_DSN=postgresql://argmcp:secret@localhost:5432/argmcp
